        $(".language a.lang-en").attr("href", "/en/our-team");
        $(".language a.lang-de").attr("href", "/de/unser-team");
        break;
      case '/en/programs':     
        $(".language a.lang-en").attr("href", "/en/programs");
        $(".language a.lang-de").attr("href", "/de/programme");
        break;
      case '/de/programme': 
        $(".language a.lang-en").attr("href", "/en/programs");
        $(".language a.lang-de").attr("href", "/de/programme");
        break;
      case '/en/news': 
        $(".language a.lang-en").attr("href", "/en/news");
        $(".language a.lang-de").attr("href", "/de/neuigkeiten");
        break;
      case '/de/neuigkeiten': 
        $(".language a.lang-en").attr("href", "/en/news");
        $(".language a.lang-de").attr("href", "/de/neuigkeiten");
        break;
      case '/en/contact': 
        $(".language a.lang-en").attr("href", "/en/contact");
        $(".language a.lang-de").attr("href", "/de/kontakt");
        break;
      case '/de/kontakt': 
        $(".language a.lang-en").attr("href", "/en/contact");
        $(".language a.lang-de").attr("href", "/de/kontakt");
        break;
      case '/en/urbana': 
        $(".language a.lang-en").attr("href", "/en/urbana");
        $(".language a.lang-de").attr("href", "/de/urbana");
        break;
      case '/de/urbana': 
        $(".language a.lang-en").attr("href", "/en/urbana");
        $(".language a.lang-de").attr("href", "/de/urbana");
        break;
      case '/en/leap': 
        $(".language a.lang-en").attr("href", "/en/leap");
        $(".language a.lang-de").attr("href", "/de/leap");
        break;
      case '/de/leap': 
        $(".language a.lang-en").attr("href", "/en/leap");
        $(".language a.lang-de").attr("href", "/de/leap");
        break;
      case '/en/interactonline': 
        $(".language a.lang-en").attr("href", "/en/interactonline");
        $(".language a.lang-de").attr("href", "/de/interactonline");
        break;
      case '/de/interactonline': 
        $(".language a.lang-en").attr("href", "/en/interactonline");
        $(".language a.lang-de").attr("href", "/de/interactonline");
        break;
    }
  });    
</script>
